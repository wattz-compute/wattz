# apps/web -- local environment example.
# Copy to .env.local. Only NEXT_PUBLIC_* values reach the browser bundle;
# everything else stays server-side (Route Handlers under src/app/api).

# ----- Server-only -----
# Inference gateway the Route Handlers proxy to (same-origin /api/* -> gateway).
INFERENCE_GATEWAY_URL=https://api.wattz.fi
# Bearer token the gateway expects, if configured. Leave empty for open relay.
GATEWAY_AUTH_TOKEN=
# API key forwarded to the gateway for authenticated inference calls.
WATTZ_API_KEY=

# ----- Client-safe (NEXT_PUBLIC_) -----
# Public Solana RPC only. Never a keyed Helius / QuickNode URL.
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_SITE_URL=https://wattz.fi
# Marketplace program on Solana devnet.
NEXT_PUBLIC_2_PROGRAM_ID=GUDVbE4Jgmtu8jgxUVtq2wUmjdLxJzPqT3zET2EdTLiU
# $WATTZ contract address. Empty until the mint launches; the UI hides the
# chip while this is empty.
NEXT_PUBLIC_0_PROJECT_CA=
NEXT_PUBLIC_TWITTER=wattzfi
NEXT_PUBLIC_GITHUB=wattz-compute/wattz
NEXT_PUBLIC_YOUTUBE_BGM_ID=
