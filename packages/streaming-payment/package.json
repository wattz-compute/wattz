{
  "name": "@wattz/streaming-payment",
  "version": "0.1.0",
  "description": "Wattz streaming payment. Token-2022 transfer hook + per-token SSE micro payment.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.3",
    "@solana/spl-token": "^0.4.9"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.2",
    "vitest": "^2.1.4"
  }
}
