# =====================================================
# Wattz -- Environment Variables Example
# =====================================================
# Copy this to .env and fill values. Server-only (no NEXT_PUBLIC_ prefix
# unless explicitly marked as client-safe).

# ----- Server-only (secrets) -----
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=REPLACE
HELIUS_WS_URL=wss://mainnet.helius-rpc.com/?api-key=REPLACE
LASERSTREAM_URL=https://laserstream-mainnet-tyo.helius-rpc.com/
LASERSTREAM_KEY=REPLACE
ANTHROPIC_API_KEY=REPLACE
FAL_KEY=REPLACE
TELEGRAM_BOT_TOKEN=REPLACE
TELEGRAM_CHAT_ID=REPLACE
DATABASE_URL=postgres://user:pass@host:5432/wattz
REDIS_URL=redis://host:6379
ANCHOR_KEYPAIR=/path/to/keypair.json
ANCHOR_PROGRAM_ID=REPLACE
BOOTSTRAP_NODE_HTTP=http://bootstrap-node.internal:8080
BOOTSTRAP_NODE_TOKEN=REPLACE
INFERENCE_GATEWAY_URL=http://localhost:8080
NODE_HTTP_LISTEN=0.0.0.0:8081

# ----- CORS (backend) -----
CORS_ORIGINS=https://wattz-web.vercel.app,https://wattz.ai,https://www.wattz.ai,http://localhost:3000

# ----- Client-safe (NEXT_PUBLIC_) -----
NEXT_PUBLIC_SOLANA_RPC=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_API_URL=https://api.wattz.ai
NEXT_PUBLIC_0_PROJECT_CA=
NEXT_PUBLIC_1_PLAYGROUND=true
NEXT_PUBLIC_2_SDK=true
NEXT_PUBLIC_2_PROGRAM_ID=
NEXT_PUBLIC_3_OPERATOR=true
NEXT_PUBLIC_TWITTER=wattzfi
NEXT_PUBLIC_GITHUB=wattz-labs/wattz-inference-gateway
NEXT_PUBLIC_YOUTUBE_BGM_ID=

# ----- Bootstrap node (Runpod / Vast.ai option A) -----
RUNPOD_API_KEY=
VAST_API_KEY=
LAMBDA_API_KEY=

# ----- Model registry credentials -----
HUGGINGFACE_TOKEN=
