# =====================================================
# Wattz -- environment variables example
# =====================================================
# Copy to .env and fill in. Only NEXT_PUBLIC_* values reach the browser
# bundle; everything else is server-side. Never give a secret a
# NEXT_PUBLIC_ prefix.

# ----- Solana -----
# Public RPC used by the wallet adapter in the browser (keyless).
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
# Server-side RPC for the gateway / node-runtime. May be a keyed provider.
SOLANA_RPC_URL=https://api.devnet.solana.com
# Optional keyed RPC (server-side only, never NEXT_PUBLIC_).
HELIUS_RPC_URL=
HELIUS_WS_URL=

# ----- Anchor / marketplace program (devnet) -----
ANCHOR_PROGRAM_ID=GUDVbE4Jgmtu8jgxUVtq2wUmjdLxJzPqT3zET2EdTLiU
ANCHOR_KEYPAIR=/path/to/settlement-keypair.json
MODEL_REGISTRY_PROGRAM_ID=GUDVbE4Jgmtu8jgxUVtq2wUmjdLxJzPqT3zET2EdTLiU
MODEL_REGISTRY_PDA=

# ----- Inference gateway -----
LISTEN_ADDR=0.0.0.0:8080
UPSTREAM_TIMEOUT_SECS=120
HEALTH_INTERVAL_SECS=15
ROUTING_WEIGHTS=price:0.3,latency:0.3,reputation:0.4
# Comma-separated node endpoints the routing engine seeds with.
WATTZ_STATIC_NODES=
# Bootstrap node the gateway falls back to before external nodes register.
BOOTSTRAP_NODE_HTTP=http://bootstrap-node.internal:8080
BOOTSTRAP_NODE_TOKEN=
# Relay path: inference is relayed through Groq LPU capacity until the first
# bare-metal node registers. The wire protocol does not change.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_FALLBACK_ENABLED=true

# ----- Web / operator apps -> gateway -----
INFERENCE_GATEWAY_URL=http://localhost:8080
GATEWAY_AUTH_TOKEN=
NODE_HTTP_LISTEN=0.0.0.0:8081

# ----- CORS (gateway) -----
CORS_ORIGINS=https://wattz-web.vercel.app,https://wattz.fi,https://www.wattz.fi,http://localhost:3000

# ----- Client-safe (NEXT_PUBLIC_) -----
NEXT_PUBLIC_API_URL=https://api.wattz.fi
NEXT_PUBLIC_SITE_URL=https://wattz.fi
NEXT_PUBLIC_0_PROJECT_CA=
NEXT_PUBLIC_2_PROGRAM_ID=GUDVbE4Jgmtu8jgxUVtq2wUmjdLxJzPqT3zET2EdTLiU
NEXT_PUBLIC_TWITTER=wattzfi
NEXT_PUBLIC_GITHUB=wattz-compute/wattz
NEXT_PUBLIC_YOUTUBE_BGM_ID=

# ----- Node operator (bootstrap-nodes deploy scripts) -----
RUNPOD_API_KEY=
VAST_API_KEY=
LAMBDA_API_KEY=
HUGGINGFACE_TOKEN=
